<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.res.mapper.ResWorkgroupToolMapper">
    
    <resultMap type="ResWorkgroupTool" id="ResWorkgroupToolResult">
        <result property="id"    column="id"    />
        <result property="groupId"    column="group_id"    />
        <result property="toolId"    column="tool_id"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectResWorkgroupToolVo">
        select id, group_id, tool_id, remark, create_by, create_time, update_by, update_time from res_workgroup_tool
    </sql>

    <select id="selectResWorkgroupToolList" parameterType="ResWorkgroupTool" resultMap="ResWorkgroupToolResult">
        <include refid="selectResWorkgroupToolVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="groupId != null "> and group_id = #{groupId}</if>
            <if test="toolId != null "> and tool_id = #{toolId}</if>
        </where>
    </select>
    
    <select id="selectResWorkgroupToolById" parameterType="Long" resultMap="ResWorkgroupToolResult">
        <include refid="selectResWorkgroupToolVo"/>
        where id = #{id}
    </select>

    <select id="selectResWorkgroupToolListByGroupId" parameterType="Long" resultMap="ResWorkgroupToolResult">
        <include refid="selectResWorkgroupToolVo"/>
        where group_id = #{groupId}
    </select>

    <select id="selectResWorkgroupToolListByToolId" parameterType="Long" resultMap="ResWorkgroupToolResult">
        <include refid="selectResWorkgroupToolVo"/>
        where tool_id = #{toolId}
    </select>
        
    <insert id="insertResWorkgroupTool" parameterType="ResWorkgroupTool" useGeneratedKeys="true" keyProperty="id">
        insert into res_workgroup_tool
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="groupId != null">group_id,</if>
            <if test="toolId != null">tool_id,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="groupId != null">#{groupId},</if>
            <if test="toolId != null">#{toolId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateResWorkgroupTool" parameterType="ResWorkgroupTool">
        update res_workgroup_tool
        <trim prefix="SET" suffixOverrides=",">
            <if test="groupId != null">group_id = #{groupId},</if>
            <if test="toolId != null">tool_id = #{toolId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteResWorkgroupToolById" parameterType="Long">
        delete from res_workgroup_tool where id = #{id}
    </delete>

    <delete id="deleteResWorkgroupToolByIds" parameterType="String">
        delete from res_workgroup_tool where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteResWorkgroupToolByGroupId" parameterType="Long">
        delete from res_workgroup_tool where group_id = #{groupId}
    </delete>

    <delete id="deleteResWorkgroupToolByToolId" parameterType="Long">
        delete from res_workgroup_tool where tool_id = #{toolId}
    </delete>
</mapper>