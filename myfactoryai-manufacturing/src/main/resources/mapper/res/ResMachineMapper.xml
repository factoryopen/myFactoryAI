<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.res.mapper.ResMachineMapper">
    
    <resultMap type="ResMachine" id="ResMachineResult">
        <result property="id"    column="id"    />
        <result property="machineCode"    column="machine_code"    />
        <result property="machineName"    column="machine_name"    />
        <result property="typeId"    column="type_id"    />
        <result property="lineId"    column="line_id"    />
        <result property="enableIiot"    column="enable_iiot"    />
        <result property="ip"    column="ip"    />
        <result property="buyDay"    column="buy_day"    />
        <result property="isBusy"    column="is_busy"    />
        <result property="ioTime"    column="io_time"    />
        <result property="wsId"    column="ws_id"    />
        <result property="wsNo"    column="ws_no"    />
        <result property="mlId"    column="ml_id"    />
        <result property="mlNo"    column="ml_no"    />
        <result property="processSeq"    column="process_seq"    />
        <result property="processId"    column="process_id"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectResMachineVo">
        select id, machine_code, machine_name, type_id, line_id, enable_iiot, ip, buy_day, is_busy, io_time, ws_id, ws_no, ml_id, ml_no, process_seq, process_id, remark, create_by, create_time, update_by, update_time from res_machine
    </sql>

    <select id="selectResMachineList" parameterType="ResMachine" resultMap="ResMachineResult">
        <include refid="selectResMachineVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="machineCode != null  and machineCode != ''"> and machine_code like concat('%', #{machineCode}, '%')</if>
            <if test="machineName != null  and machineName != ''"> and machine_name like concat('%', #{machineName}, '%')</if>
            <if test="typeId != null "> and type_id = #{typeId}</if>
            <if test="lineId != null "> and line_id = #{lineId}</if>
            <if test="enableIiot != null  and enableIiot != ''"> and enable_iiot = #{enableIiot}</if>
            <if test="ip != null  and ip != ''"> and ip = #{ip}</if>
            <if test="buyDay != null "> and buy_day = #{buyDay}</if>
            <if test="isBusy != null  and isBusy != ''"> and is_busy = #{isBusy}</if>
            <if test="ioTime != null "> and io_time = #{ioTime}</if>
            <if test="wsId != null"> and ws_id = #{wsId}</if>
            <if test="wsNo != null  and wsNo != ''"> and ws_no like concat('%', #{wsNo}, '%')</if>
            <if test="mlId != null "> and ml_id = #{mlId}</if>
            <if test="mlNo != null  and mlNo != ''"> and ml_no like concat('%', #{mlNo}, '%')</if>
            <if test="processSeq != null "> and process_seq = #{processSeq}</if>
            <if test="processId != null "> and process_id = #{processId}</if>
        </where>
        order by is_busy desc,update_time desc
    </select>
    
    <select id="selectResMachineById" parameterType="Long" resultMap="ResMachineResult">
        <include refid="selectResMachineVo"/>
        where id = #{id}
    </select>

    <select id="selectResMachineByCode" parameterType="String" resultMap="ResMachineResult">
        <include refid="selectResMachineVo"/>
        where machine_code = #{machineCode}
    </select>

    <select id="selectResMachineListByTypeId" parameterType="Long" resultMap="ResMachineResult">
        <include refid="selectResMachineVo"/>
        where type_id = #{typeId}
    </select>

    <select id="selectResMachineListByLineId" parameterType="Long" resultMap="ResMachineResult">
        <include refid="selectResMachineVo"/>
        where line_id = #{lineId}
    </select>

    <select id="selectResMachineListByProcessId" parameterType="Long" resultMap="ResMachineResult">
        <include refid="selectResMachineVo"/>
        where process_id = #{processId}
    </select>
        
    <insert id="insertResMachine" parameterType="ResMachine" useGeneratedKeys="true" keyProperty="id">
        insert into res_machine
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="machineCode != null and machineCode != ''">machine_code,</if>
            <if test="machineName != null and machineName != ''">machine_name,</if>
            <if test="typeId != null">type_id,</if>
            <if test="lineId != null">line_id,</if>
            <if test="enableIiot != null and enableIiot != ''">enable_iiot,</if>
            <if test="ip != null">ip,</if>
            <if test="buyDay != null">buy_day,</if>
            <if test="isBusy != null">is_busy,</if>
            <if test="ioTime != null">io_time,</if>
            <if test="wsId != null">ws_id,</if>
            <if test="wsNo != null">ws_no,</if>
            <if test="mlId != null">ml_id,</if>
            <if test="mlNo != null">ml_no,</if>
            <if test="processSeq != null">process_seq,</if>
            <if test="processId != null">process_id,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="machineCode != null and machineCode != ''">#{machineCode},</if>
            <if test="machineName != null and machineName != ''">#{machineName},</if>
            <if test="typeId != null">#{typeId},</if>
            <if test="lineId != null">#{lineId},</if>
            <if test="enableIiot != null and enableIiot != ''">#{enableIiot},</if>
            <if test="ip != null">#{ip},</if>
            <if test="buyDay != null">#{buyDay},</if>
            <if test="isBusy != null">#{isBusy},</if>
            <if test="ioTime != null">#{ioTime},</if>
            <if test="wsId != null">#{wsId},</if>
            <if test="wsNo != null">#{wsNo},</if>
            <if test="mlId != null">#{mlId},</if>
            <if test="mlNo != null">#{mlNo},</if>
            <if test="processSeq != null">#{processSeq},</if>
            <if test="processId != null">#{processId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateResMachine" parameterType="ResMachine">
        update res_machine
        <trim prefix="SET" suffixOverrides=",">
            <if test="machineCode != null and machineCode != ''">machine_code = #{machineCode},</if>
            <if test="machineName != null and machineName != ''">machine_name = #{machineName},</if>
            <if test="typeId != null">type_id = #{typeId},</if>
            <if test="lineId != null">line_id = #{lineId},</if>
            <if test="enableIiot != null and enableIiot != ''">enable_iiot = #{enableIiot},</if>
            <if test="ip != null">ip = #{ip},</if>
            <if test="buyDay != null">buy_day = #{buyDay},</if>
            <if test="isBusy != null">is_busy = #{isBusy},</if>
            io_time = #{ioTime},
            ws_id = #{wsId},
            ws_no = #{wsNo},
            ml_id = #{mlId},
            ml_no = #{mlNo},
            process_seq = #{processSeq},
            process_id = #{processId},
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteResMachineById" parameterType="Long">
        delete from res_machine where id = #{id}
    </delete>

    <delete id="deleteResMachineByIds" parameterType="String">
        delete from res_machine where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteResMachineByTypeId" parameterType="Long">
        delete from res_machine where type_id = #{typeId}
    </delete>

    <delete id="deleteResMachineByLineId" parameterType="Long">
        delete from res_machine where line_id = #{lineId}
    </delete>

    <delete id="deleteResMachineByProcessId" parameterType="Long">
        delete from res_machine where process_id = #{processId}
    </delete>
</mapper>