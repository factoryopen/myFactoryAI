<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.res.mapper.ResWareHouseMapper">
    
    <resultMap type="ResWareHouse" id="ResWareHouseResult">
        <result property="id"    column="id"    />
        <result property="houseCode"    column="house_code"    />
        <result property="houseName"    column="house_name"    />
        <result property="houseLocation"    column="house_location"    />
        <result property="houseType"    column="house_type"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectResWareHouseVo">
        select id, house_code, house_name, house_location, house_type, status, remark, create_by, create_time, update_by, update_time from res_ware_house
    </sql>

    <select id="selectResWareHouseList" parameterType="ResWareHouse" resultMap="ResWareHouseResult">
        <include refid="selectResWareHouseVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="houseCode != null  and houseCode != ''"> and house_code like concat('%', #{houseCode}, '%')</if>
            <if test="houseName != null  and houseName != ''"> and house_name like concat('%', #{houseName}, '%')</if>
            <if test="houseLocation != null  and houseLocation != ''"> and house_location = #{houseLocation}</if>
            <if test="houseType != null "> and house_type = #{houseType}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectResWareHouseById" parameterType="Long" resultMap="ResWareHouseResult">
        <include refid="selectResWareHouseVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertResWareHouse" parameterType="ResWareHouse" useGeneratedKeys="true" keyProperty="id">
        insert into res_ware_house
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="houseCode != null">house_code,</if>
            <if test="houseName != null">house_name,</if>
            <if test="houseLocation != null">house_location,</if>
            <if test="houseType != null">house_type,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="houseCode != null">#{houseCode},</if>
            <if test="houseName != null">#{houseName},</if>
            <if test="houseLocation != null">#{houseLocation},</if>
            <if test="houseType != null">#{houseType},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateResWareHouse" parameterType="ResWareHouse">
        update res_ware_house
        <trim prefix="SET" suffixOverrides=",">
            <if test="houseCode != null">house_code = #{houseCode},</if>
            <if test="houseName != null">house_name = #{houseName},</if>
            <if test="houseLocation != null">house_location = #{houseLocation},</if>
            <if test="houseType != null">house_type = #{houseType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteResWareHouseById" parameterType="Long">
        delete from res_ware_house where id = #{id}
    </delete>

    <delete id="deleteResWareHouseByIds" parameterType="String">
        delete from res_ware_house where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>