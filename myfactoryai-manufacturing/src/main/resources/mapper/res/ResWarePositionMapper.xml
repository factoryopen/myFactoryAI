<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.res.mapper.ResWarePositionMapper">
    
    <resultMap type="ResWarePosition" id="ResWarePositionResult">
        <result property="id"    column="id"    />
        <result property="positionCode"    column="position_code"    />
        <result property="positionName"    column="position_name"    />
        <result property="positionLocation"    column="position_location"    />
        <result property="houseId"    column="house_id"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectResWarePositionVo">
        select id, position_code, position_name, position_location, house_id, status, remark, create_by, create_time, update_by, update_time from res_ware_position
    </sql>

    <select id="selectResWarePositionList" parameterType="ResWarePosition" resultMap="ResWarePositionResult">
        <include refid="selectResWarePositionVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="positionCode != null  and positionCode != ''"> and position_code like concat('%', #{positionCode}, '%')</if>
            <if test="positionName != null  and positionName != ''"> and position_name like concat('%', #{positionName}, '%')</if>
            <if test="positionLocation != null  and positionLocation != ''"> and position_location = #{positionLocation}</if>
            <if test="houseId != null "> and house_id = #{houseId}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectResWarePositionById" parameterType="Long" resultMap="ResWarePositionResult">
        <include refid="selectResWarePositionVo"/>
        where id = #{id}
    </select>

    <select id="selectResWarePositionListByHouseId" parameterType="Long" resultMap="ResWarePositionResult">
        <include refid="selectResWarePositionVo"/>
        where house_id = #{houseId}
    </select>
        
    <insert id="insertResWarePosition" parameterType="ResWarePosition" useGeneratedKeys="true" keyProperty="id">
        insert into res_ware_position
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="positionCode != null and positionCode != ''">position_code,</if>
            <if test="positionName != null">position_name,</if>
            <if test="positionLocation != null">position_location,</if>
            <if test="houseId != null">house_id,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="positionCode != null and positionCode != ''">#{positionCode},</if>
            <if test="positionName != null">#{positionName},</if>
            <if test="positionLocation != null">#{positionLocation},</if>
            <if test="houseId != null">#{houseId},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateResWarePosition" parameterType="ResWarePosition">
        update res_ware_position
        <trim prefix="SET" suffixOverrides=",">
            <if test="positionCode != null and positionCode != ''">position_code = #{positionCode},</if>
            <if test="positionName != null">position_name = #{positionName},</if>
            <if test="positionLocation != null">position_location = #{positionLocation},</if>
            <if test="houseId != null">house_id = #{houseId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteResWarePositionById" parameterType="Long">
        delete from res_ware_position where id = #{id}
    </delete>

    <delete id="deleteResWarePositionByIds" parameterType="String">
        delete from res_ware_position where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteResWarePositionByHouseId" parameterType="Long">
        delete from res_ware_position where house_id = #{houseId}
    </delete>
</mapper>