<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.sup.mapper.SupPoItemReturnMapper">
    
    <resultMap type="SupPoItemReturn" id="SupPoItemReturnResult">
        <result property="id"    column="id"    />
        <result property="poId"    column="po_id"    />
        <result property="seqNo"    column="seq_no"    />
        <result property="status"    column="status"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="purchasingType"    column="purchasing_type"    />
        <result property="materialId"    column="material_id"    />
        <result property="materialCode"    column="material_code"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialSpec"    column="material_spec"    />
        <result property="drawNo"    column="draw_no"    />
        <result property="unitId"    column="unit_id"    />
        <result property="quantityReturning"    column="quantity_returning"    />
        <result property="quantityReturned"    column="quantity_returned"    />
        <result property="sourceBillId"    column="source_bill_id"    />
        <result property="sourceBillNo"    column="source_bill_no"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectSupPoItemReturnVo">
        select id, po_id, seq_no, status, supplier_id, purchasing_type, material_id, material_code, material_name, material_spec,draw_no,
               unit_id, quantity_returning, quantity_returned, source_bill_id, source_bill_no,
               remark, create_by, create_time, update_by, update_time
        from sup_po_item_return
    </sql>

    <select id="selectSupPoItemReturnList" parameterType="SupPoItemReturn" resultMap="SupPoItemReturnResult">
        <include refid="selectSupPoItemReturnVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="poId != null "> and po_id = #{poId}</if>
            <if test="seqNo != null"> and seq_no ={seqNo}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="supplierId != null "> and supplier_id = #{supplierId}</if>
            <if test="purchasingType != null "> and purchasing_type = #{purchasingType}</if>
            <if test="materialId != null "> and material_id = #{materialId}</if>
            <if test="materialCode != null  and materialCode != ''"> and material_code like concat('%', #{materialCode}, '%')</if>
            <if test="materialName != null  and materialName != ''"> and material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialSpec != null  and materialSpec != ''"> and material_spec like concat('%', #{materialSpec}, '%')</if>
            <if test="drawNo != null  and drawNo != ''"> and draw_no like concat('%', #{drawNo}, '%')</if>
            <if test="unitId != null "> and unit_id = #{unitId}</if>
            <if test="quantityReturning != null "> and quantity_returning = #{quantityReturning}</if>
            <if test="quantityReturned != null "> and quantity_returned = #{quantityReturned}</if>
            <if test="sourceBillId != null "> and source_bill_id = #{sourceBillId}</if>
            <if test="sourceBillNo != null  and sourceBillNo != ''"> and source_bill_no like concat('%', #{sourceBillNo}, '%')</if>
        </where>
    </select>
    
    <select id="selectSupPoItemReturnById" parameterType="Long" resultMap="SupPoItemReturnResult">
        <include refid="selectSupPoItemReturnVo"/>
        where id = #{id}
    </select>

    <select id="selectSupPoItemReturnListByPoId" parameterType="Long" resultMap="SupPoItemReturnResult">
        <include refid="selectSupPoItemReturnVo"/>
        where po_id = #{poId}
    </select>

    <select id="selectSupPoItemReturnListBySupplierId" parameterType="Long" resultMap="SupPoItemReturnResult">
        <include refid="selectSupPoItemReturnVo"/>
        where supplier_id = #{supplierId}
    </select>

    <select id="selectSupPoItemReturnListByMaterialId" parameterType="Long" resultMap="SupPoItemReturnResult">
        <include refid="selectSupPoItemReturnVo"/>
        where material_id = #{materialId}
    </select>
        
    <insert id="insertSupPoItemReturn" parameterType="SupPoItemReturn" useGeneratedKeys="true" keyProperty="id">
        insert into sup_po_item_return
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="poId != null">po_id,</if>
            <if test="seqNo != null">seq_no,</if>
            <if test="status != null">status,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="purchasingType != null">purchasing_type,</if>
            <if test="materialId != null">material_id,</if>
            <if test="materialCode != null and materialCode != ''">material_code,</if>
            <if test="materialName != null">material_name,</if>
            <if test="materialSpec != null">material_spec,</if>
            <if test="drawNo != null  and drawNo != ''">draw_no,</if>
            <if test="unitId != null">unit_id,</if>
            <if test="quantityReturning != null">quantity_returning,</if>
            <if test="quantityReturned != null">quantity_returned,</if>
            <if test="sourceBillId != null">source_bill_id,</if>
            <if test="sourceBillNo != null">source_bill_no,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="poId != null">#{poId},</if>
            <if test="seqNo != null">#{seqNo},</if>
            <if test="status != null">#{status},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="purchasingType != null">#{purchasingType},</if>
            <if test="materialId != null">#{materialId},</if>
            <if test="materialCode != null and materialCode != ''">#{materialCode},</if>
            <if test="materialName != null">#{materialName},</if>
            <if test="materialSpec != null">#{materialSpec},</if>
            <if test="drawNo != null  and drawNo != ''">#{drawNo},</if>
            <if test="unitId != null">#{unitId},</if>
            <if test="quantityReturning != null">#{quantityReturning},</if>
            <if test="quantityReturned != null">#{quantityReturned},</if>
            <if test="sourceBillId != null">#{sourceBillId},</if>
            <if test="sourceBillNo != null">#{sourceBillNo},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateSupPoItemReturn" parameterType="SupPoItemReturn">
        update sup_po_item_return
        <trim prefix="SET" suffixOverrides=",">
            <if test="poId != null">po_id = #{poId},</if>
            <if test="seqNo != null">seq_no = #{seqNo},</if>
            <if test="status != null">status = #{status},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="purchasingType != null">purchasing_type = #{purchasingType},</if>
            <if test="materialId != null">material_id = #{materialId},</if>
            <if test="materialCode != null and materialCode != ''">material_code = #{materialCode},</if>
            <if test="materialName != null">material_name = #{materialName},</if>
            <if test="materialSpec != null">material_spec = #{materialSpec},</if>
            <if test="drawNo != null  and drawNo != ''">draw_no=#{drawNo},</if>
            <if test="unitId != null">unit_id = #{unitId},</if>
            <if test="quantityReturning != null">quantity_returning = #{quantityReturning},</if>
            <if test="quantityReturned != null">quantity_returned = #{quantityReturned},</if>
            <if test="sourceBillId != null">source_bill_id = #{sourceBillId},</if>
            <if test="sourceBillNo != null">source_bill_no = #{sourceBillNo},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSupPoItemReturnById" parameterType="Long">
        delete from sup_po_item_return where id = #{id}
    </delete>

    <delete id="deleteSupPoItemReturnByIds" parameterType="String">
        delete from sup_po_item_return where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteSupPoItemReturnByPoId" parameterType="Long">
        delete from sup_po_item_return where po_id = #{poId}
    </delete>

    <delete id="deleteSupPoItemReturnBySupplierId" parameterType="Long">
        delete from sup_po_item_return where supplier_id = #{supplierId}
    </delete>

    <delete id="deleteSupPoItemReturnByMaterialId" parameterType="Long">
        delete from sup_po_item_return where material_id = #{materialId}
    </delete>
</mapper>