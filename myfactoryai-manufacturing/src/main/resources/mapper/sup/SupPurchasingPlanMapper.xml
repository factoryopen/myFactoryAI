    <sql id="selectSupPurchasingPlanVo">
        select id, bill_no, status, material_code, material_id, material_name, material_spec,draw_no,
               unit_id, quantity, price, amount, require_day, priority, purchasing_type, customer_id, customer_name, price_sale,
               source_bill_id, source_bill_no, pr_id, pr_item_id, consume_type, enable_must, enable_replace,
               remark, create_by, create_time, update_by, update_time
        from sup_purchasing_plan
    </sql>

    <select id="selectSupPurchasingPlanList" parameterType="SupPurchasingPlan" resultMap="SupPurchasingPlanResult">
        <include refid="selectSupPurchasingPlanVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="billNo != null  and billNo != ''"> and bill_no like concat('%', #{billNo}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="materialId != null "> and material_id = #{materialId}</if>
            <if test="materialCode != null  and materialCode != ''"> and material_code like concat('%', #{materialCode}, '%')</if>
            <if test="materialName != null  and materialName != ''"> and material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialSpec != null  and materialSpec != ''"> and material_spec like concat('%', #{materialSpec}, '%')</if>
            <if test="drawNo != null  and drawNo != ''"> and draw_no like concat('%', #{drawNo}, '%')</if>
            <if test="unitId != null "> and unit_id = #{unitId}</if>
            <if test="quantity != null "> and quantity = #{quantity}</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="amount != null "> and amount = #{amount}</if>
            <if test="requireDay != null "> and require_day = #{requireDay}</if>
            <if test="priority != null "> and priority = #{priority}</if>
            <if test="purchasingType != null "> and purchasing_type = #{purchasingType}</if>
            <if test="customerId != null "> and customer_id = #{customerId}</if>
            <if test="customerName != null "> and customer_name like concat('%', #{customerName}, '%')</if>
            <if test="priceSale != null "> and price_sale = #{priceSale}</if>
            <if test="sourceBillId != null "> and source_bill_id = #{sourceBillId}</if>
            <if test="sourceBillNo != null  and sourceBillNo != ''"> and source_bill_no like concat('%', #{sourceBillNo}, '%')</if>
            <if test="prId != null "> and pr_id = #{prId}</if>
            <if test="prItemId != null "> and pr_item_id = #{prItemId}</if>
            <if test="consumeType != null "> and consume_type = #{consumeType}</if>
            <if test="enableMust != null  and enableMust != ''"> and enable_must = #{enableMust}</if>
            <if test="enableReplace != null  and enableReplace != ''"> and enable_replace = #{enableReplace}</if>
             and status in (0,4,13,14)
        </where>
        order by update_time desc
    </select>
    
    <select id="selectSupPurchasingPlanById" parameterType="Long" resultMap="SupPurchasingPlanResult">
        <include refid="selectSupPurchasingPlanVo"/>
