<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.sup.mapper.SupPurchaseRequestMapper">
    
    <resultMap type="SupPurchaseRequest" id="SupPurchaseRequestResult">
        <result property="id"    column="id"    />
        <result property="billNo"    column="bill_no"    />
        <result property="status"    column="status"    />
        <result property="purchasingType"    column="purchasing_type"    />
        <result property="requestDay"    column="request_day"    />
        <result property="requestorId"    column="requestor_id"    />
        <result property="deptId"    column="dept_id"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectSupPurchaseRequestVo">
        select id, bill_no, status, purchasing_type, request_day, requestor_id, dept_id, remark, create_by, create_time, update_by, update_time from sup_pr
    </sql>

    <select id="selectSupPurchaseRequestList" parameterType="SupPurchaseRequest" resultMap="SupPurchaseRequestResult">
        <include refid="selectSupPurchaseRequestVo"/>
        <where>
            create_by= #{createBy}
            <if test="id != null "> and id = #{id}</if>
            <if test="billNo != null  and billNo != ''"> and bill_no like concat('%', #{billNo}, '%')</if>
                 and status in (0,1,2,3,13)
                 and purchasing_type in (5,6,7,8,9,10)
            <if test="status != null "> and status = #{status}</if>
            <if test="purchasingType != null "> and purchasing_type = #{purchasingType}</if>
            <if test="requestDay != null "> and request_day = #{requestDay}</if>
            <if test="requestorId != null "> and requestor_id = #{requestorId}</if>
            <if test="deptId != null "> and dept_id = #{deptId}</if>
        </where>
        order by update_time desc
    </select>

    <select id="selectSupPurchaseRequestList4fk" parameterType="SupPurchaseRequest" resultMap="SupPurchaseRequestResult">
        <include refid="selectSupPurchaseRequestVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="billNo != null  and billNo != ''"> and bill_no like concat('%', #{billNo}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="purchasingType != null "> and purchasing_type = #{purchasingType}</if>
            <if test="requestDay != null "> and request_day = #{requestDay}</if>
            <if test="requestorId != null "> and requestor_id = #{requestorId}</if>
            <if test="deptId != null "> and dept_id = #{deptId}</if>
        </where>
    </select>
    
    <select id="selectSupPurchaseRequestById" parameterType="Long" resultMap="SupPurchaseRequestResult">
        <include refid="selectSupPurchaseRequestVo"/>
        where id = #{id}
    </select>

    <select id="selectSupPurchaseRequestListByRequestorId" parameterType="Long" resultMap="SupPurchaseRequestResult">
        <include refid="selectSupPurchaseRequestVo"/>
        where requestor_id = #{requestorId}
    </select>

    <select id="selectSupPurchaseRequestListByDeptId" parameterType="Long" resultMap="SupPurchaseRequestResult">
        <include refid="selectSupPurchaseRequestVo"/>
        where dept_id = #{deptId}
    </select>
        
    <insert id="insertSupPurchaseRequest" parameterType="SupPurchaseRequest" useGeneratedKeys="true" keyProperty="id">
        insert into sup_pr
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no,</if>
            <if test="status != null">status,</if>
            <if test="purchasingType != null">purchasing_type,</if>
            <if test="requestDay != null">request_day,</if>
            <if test="requestorId != null">requestor_id,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">#{billNo},</if>
            <if test="status != null">#{status},</if>
            <if test="purchasingType != null">#{purchasingType},</if>
            <if test="requestDay != null">#{requestDay},</if>
            <if test="requestorId != null">#{requestorId},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateSupPurchaseRequest" parameterType="SupPurchaseRequest">
        update sup_pr
        <trim prefix="SET" suffixOverrides=",">
            <if test="billNo != null and billNo != ''">bill_no = #{billNo},</if>
            <if test="status != null">status = #{status},</if>
            <if test="purchasingType != null">purchasing_type = #{purchasingType},</if>
            <if test="requestDay != null">request_day = #{requestDay},</if>
            <if test="requestorId != null">requestor_id = #{requestorId},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSupPurchaseRequestById" parameterType="Long">
        delete from sup_pr where id = #{id}
    </delete>

    <delete id="deleteSupPurchaseRequestByIds" parameterType="String">
        delete from sup_pr where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteSupPurchaseRequestByRequestorId" parameterType="Long">
        delete from sup_pr where requestor_id = #{requestorId}
    </delete>

    <delete id="deleteSupPurchaseRequestByDeptId" parameterType="Long">
        delete from sup_pr where dept_id = #{deptId}
    </delete>
</mapper>