<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.sup.mapper.SupSupplierQuotaMapper">
    
    <resultMap type="SupSupplierQuota" id="SupSupplierQuotaResult">
        <result property="id"    column="id"    />
        <result property="materialId"    column="material_id"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialSpec"    column="material_spec"    />
        <result property="prioritySeq"    column="priority_seq"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="quotaPercent"    column="quota_percent"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectSupSupplierQuotaVo">
        select id, material_id, material_name, material_spec, priority_seq, supplier_id, quota_percent, remark, create_by, create_time, update_by, update_time from sup_supplier_quota
    </sql>

    <select id="selectSupSupplierQuotaList" parameterType="SupSupplierQuota" resultMap="SupSupplierQuotaResult">
        <include refid="selectSupSupplierQuotaVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="materialId != null "> and material_id = #{materialId}</if>
            <if test="materialName != null  and materialName != ''"> and material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialSpec != null  and materialSpec != ''"> and material_spec like concat('%', #{materialSpec}, '%')</if>
            <if test="prioritySeq != null "> and priority_seq = #{prioritySeq}</if>
            <if test="supplierId != null "> and supplier_id = #{supplierId}</if>
            <if test="quotaPercent != null "> and quota_percent = #{quotaPercent}</if>
        </where>
    </select>
    
    <select id="selectSupSupplierQuotaById" parameterType="Long" resultMap="SupSupplierQuotaResult">
        <include refid="selectSupSupplierQuotaVo"/>
        where id = #{id}
    </select>

    <select id="selectSupSupplierQuotaListByMaterialId" parameterType="Long" resultMap="SupSupplierQuotaResult">
        <include refid="selectSupSupplierQuotaVo"/>
        where material_id = #{materialId}
    </select>

    <select id="selectSupSupplierQuotaListBySupplierId" parameterType="Long" resultMap="SupSupplierQuotaResult">
        <include refid="selectSupSupplierQuotaVo"/>
        where supplier_id = #{supplierId}
    </select>
        
    <insert id="insertSupSupplierQuota" parameterType="SupSupplierQuota" useGeneratedKeys="true" keyProperty="id">
        insert into sup_supplier_quota
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="materialId != null">material_id,</if>
            <if test="materialName != null">material_name,</if>
            <if test="materialSpec != null">material_spec,</if>
            <if test="prioritySeq != null">priority_seq,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="quotaPercent != null">quota_percent,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="materialId != null">#{materialId},</if>
            <if test="materialName != null">#{materialName},</if>
            <if test="materialSpec != null">#{materialSpec},</if>
            <if test="prioritySeq != null">#{prioritySeq},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="quotaPercent != null">#{quotaPercent},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateSupSupplierQuota" parameterType="SupSupplierQuota">
        update sup_supplier_quota
        <trim prefix="SET" suffixOverrides=",">
            <if test="materialId != null">material_id = #{materialId},</if>
            <if test="materialName != null">material_name = #{materialName},</if>
            <if test="materialSpec != null">material_spec = #{materialSpec},</if>
            <if test="prioritySeq != null">priority_seq = #{prioritySeq},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="quotaPercent != null">quota_percent = #{quotaPercent},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSupSupplierQuotaById" parameterType="Long">
        delete from sup_supplier_quota where id = #{id}
    </delete>

    <delete id="deleteSupSupplierQuotaByIds" parameterType="String">
        delete from sup_supplier_quota where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteSupSupplierQuotaByMaterialId" parameterType="Long">
        delete from sup_supplier_quota where material_id = #{materialId}
    </delete>

    <delete id="deleteSupSupplierQuotaBySupplierId" parameterType="Long">
        delete from sup_supplier_quota where supplier_id = #{supplierId}
    </delete>
</mapper>