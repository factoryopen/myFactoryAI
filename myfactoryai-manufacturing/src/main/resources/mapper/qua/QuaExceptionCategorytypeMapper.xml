<mapper namespace="net.factoryopen.myfactoryai.manufacturing.qua.mapper.QuaExceptionCategorytypeMapper">
    
    <resultMap type="QuaExceptionCategorytype" id="QuaExceptionCategorytypeResult">
        <result property="id"    column="id"    />
        <result property="categoryCode"    column="category_code"    />
        <result property="categoryDesc"    column="category_desc"    />
