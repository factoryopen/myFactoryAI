    <sql id="selectQuaExceptionCategorytypeVo">
        select id, category_code, category_desc, status, remark, create_by, create_time, update_by, update_time from qua_exception_categorytype
    </sql>

    <select id="selectQuaExceptionCategorytypeList" parameterType="QuaExceptionCategorytype" resultMap="QuaExceptionCategorytypeResult">
        <include refid="selectQuaExceptionCategorytypeVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="categoryCode != null  and categoryCode != ''"> and category_code like concat('%', #{categoryCode}, '%')</if>
            <if test="categoryDesc != null  and categoryDesc != ''"> and category_desc like concat('%', #{categoryDesc}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectQuaExceptionCategorytypeById" parameterType="Long" resultMap="QuaExceptionCategorytypeResult">
        <include refid="selectQuaExceptionCategorytypeVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertQuaExceptionCategorytype" parameterType="QuaExceptionCategorytype" useGeneratedKeys="true" keyProperty="id">
        insert into qua_exception_categorytype
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="categoryDesc != null and categoryDesc != ''">category_desc,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="categoryDesc != null and categoryDesc != ''">#{categoryDesc},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateQuaExceptionCategorytype" parameterType="QuaExceptionCategorytype">
        update qua_exception_categorytype
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="categoryDesc != null and categoryDesc != ''">category_desc = #{categoryDesc},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteQuaExceptionCategorytypeById" parameterType="Long">
        delete from qua_exception_categorytype where id = #{id}
    </delete>

    <delete id="deleteQuaExceptionCategorytypeByIds" parameterType="String">
        delete from qua_exception_categorytype where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
