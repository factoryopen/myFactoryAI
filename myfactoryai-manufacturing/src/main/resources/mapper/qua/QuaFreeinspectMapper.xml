<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.qua.mapper.QuaFreeinspectMapper">
    
    <resultMap type="QuaFreeinspect" id="QuaFreeinspectResult">
        <result property="id"    column="id"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="freeLevel"    column="free_level"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectQuaFreeinspectVo">
        select id, supplier_id, free_level, remark, create_by, create_time, update_by, update_time from qua_freeinspect
    </sql>

    <select id="selectQuaFreeinspectList" parameterType="QuaFreeinspect" resultMap="QuaFreeinspectResult">
        <include refid="selectQuaFreeinspectVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="supplierId != null "> and supplier_id = #{supplierId}</if>
            <if test="freeLevel != null "> and free_level = #{freeLevel}</if>
        </where>
    </select>
    
    <select id="selectQuaFreeinspectById" parameterType="Long" resultMap="QuaFreeinspectResult">
        <include refid="selectQuaFreeinspectVo"/>
        where id = #{id}
    </select>

    <select id="selectQuaFreeinspectListBySupplierId" parameterType="Long" resultMap="QuaFreeinspectResult">
        <include refid="selectQuaFreeinspectVo"/>
        where supplier_id = #{supplierId}
    </select>
        
    <insert id="insertQuaFreeinspect" parameterType="QuaFreeinspect" useGeneratedKeys="true" keyProperty="id">
        insert into qua_freeinspect
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="supplierId != null">supplier_id,</if>
            <if test="freeLevel != null">free_level,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="supplierId != null">#{supplierId},</if>
            <if test="freeLevel != null">#{freeLevel},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateQuaFreeinspect" parameterType="QuaFreeinspect">
        update qua_freeinspect
        <trim prefix="SET" suffixOverrides=",">
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="freeLevel != null">free_level = #{freeLevel},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteQuaFreeinspectById" parameterType="Long">
        delete from qua_freeinspect where id = #{id}
    </delete>

    <delete id="deleteQuaFreeinspectByIds" parameterType="String">
        delete from qua_freeinspect where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteQuaFreeinspectBySupplierId" parameterType="Long">
        delete from qua_freeinspect where supplier_id = #{supplierId}
    </delete>
</mapper>