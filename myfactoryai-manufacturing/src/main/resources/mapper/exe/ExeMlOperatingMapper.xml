    <select id="selectExeMlOperatingList" parameterType="ExeMlOperating" resultMap="ExeMlOperatingResult">
        <include refid="selectExeMlOperatingVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="billNo != null  and billNo != ''"> and bill_no like concat('%', #{billNo}, '%')</if>
