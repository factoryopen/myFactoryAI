            <if test="processProgress != null "> and process_progress = #{processProgress}</if>
            <if test="priority != null "> and priority = #{priority}</if>
            <if test="currentProcessId != null "> and current_process_id = #{currentProcessId}</if>
            <if test="currentWorkgroupId != null "> and current_workgroup_id = #{currentWorkgroupId}</if>
