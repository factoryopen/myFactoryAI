<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.ord.mapper.OrdProjectMapper">
    
    <resultMap type="OrdProject" id="OrdProjectResult">
        <result property="id"    column="id"    />
        <result property="projectName"    column="project_name"    />
        <result property="projectDesc"    column="project_desc"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectOrdProjectVo">
        select id, project_name, project_desc, remark, create_by, create_time, update_by, update_time from ord_project
    </sql>

    <select id="selectOrdProjectList" parameterType="OrdProject" resultMap="OrdProjectResult">
        <include refid="selectOrdProjectVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="projectName != null  and projectName != ''"> and project_name like concat('%', #{projectName}, '%')</if>
            <if test="projectDesc != null  and projectDesc != ''"> and project_desc like concat('%', #{projectDesc}, '%')</if>
        </where>
    </select>
    
    <select id="selectOrdProjectById" parameterType="Long" resultMap="OrdProjectResult">
        <include refid="selectOrdProjectVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertOrdProject" parameterType="OrdProject" useGeneratedKeys="true" keyProperty="id">
        insert into ord_project
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectName != null and projectName != ''">project_name,</if>
            <if test="projectDesc != null and projectDesc != ''">project_desc,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectName != null and projectName != ''">#{projectName},</if>
            <if test="projectDesc != null and projectDesc != ''">#{projectDesc},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateOrdProject" parameterType="OrdProject">
        update ord_project
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectName != null and projectName != ''">project_name = #{projectName},</if>
            <if test="projectDesc != null and projectDesc != ''">project_desc = #{projectDesc},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteOrdProjectById" parameterType="Long">
        delete from ord_project where id = #{id}
    </delete>

    <delete id="deleteOrdProjectByIds" parameterType="String">
        delete from ord_project where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>