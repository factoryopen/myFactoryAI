<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.bas.mapper.BasMaterialGradeMapper">
    
    <resultMap type="BasMaterialGrade" id="BasMaterialGradeResult">
        <result property="id"    column="id"    />
        <result property="grade"    column="grade"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectBasMaterialGradeVo">
        select id, grade, remark, create_by, create_time, update_by, update_time from bas_material_grade
    </sql>

    <select id="selectBasMaterialGradeList" parameterType="BasMaterialGrade" resultMap="BasMaterialGradeResult">
        <include refid="selectBasMaterialGradeVo"/>
        <where>  
            <if test="grade != null  and grade != ''"> and grade = #{grade}</if>
        </where>
    </select>
    
    <select id="selectBasMaterialGradeById" parameterType="Long" resultMap="BasMaterialGradeResult">
        <include refid="selectBasMaterialGradeVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertBasMaterialGrade" parameterType="BasMaterialGrade" useGeneratedKeys="true" keyProperty="id">
        insert into bas_material_grade
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="grade != null">grade,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="grade != null">#{grade},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateBasMaterialGrade" parameterType="BasMaterialGrade">
        update bas_material_grade
        <trim prefix="SET" suffixOverrides=",">
            <if test="grade != null">grade = #{grade},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBasMaterialGradeById" parameterType="Long">
        delete from bas_material_grade where id = #{id}
    </delete>

    <delete id="deleteBasMaterialGradeByIds" parameterType="String">
        delete from bas_material_grade where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>