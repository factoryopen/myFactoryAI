<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.bas.mapper.BasCurrencyMapper">
    
    <resultMap type="BasCurrency" id="BasCurrencyResult">
        <result property="id"    column="id"    />
        <result property="currencyName"    column="currency_name"    />
        <result property="currencySymbol"    column="currency_symbol"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectBasCurrencyVo">
        select id, currency_name, currency_symbol, remark, create_by, create_time, update_by, update_time from bas_currency
    </sql>

    <select id="selectBasCurrencyList" parameterType="BasCurrency" resultMap="BasCurrencyResult">
        <include refid="selectBasCurrencyVo"/>
        <where>  
            <if test="currencyName != null  and currencyName != ''"> and currency_name like concat('%', #{currencyName}, '%')</if>
            <if test="currencySymbol != null  and currencySymbol != ''"> and currency_symbol = #{currencySymbol}</if>
        </where>
    </select>
    
    <select id="selectBasCurrencyById" parameterType="Long" resultMap="BasCurrencyResult">
        <include refid="selectBasCurrencyVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertBasCurrency" parameterType="BasCurrency" useGeneratedKeys="true" keyProperty="id">
        insert into bas_currency
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="currencyName != null">currency_name,</if>
            <if test="currencySymbol != null">currency_symbol,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="currencyName != null">#{currencyName},</if>
            <if test="currencySymbol != null">#{currencySymbol},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateBasCurrency" parameterType="BasCurrency">
        update bas_currency
        <trim prefix="SET" suffixOverrides=",">
            <if test="currencyName != null">currency_name = #{currencyName},</if>
            <if test="currencySymbol != null">currency_symbol = #{currencySymbol},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBasCurrencyById" parameterType="Long">
        delete from bas_currency where id = #{id}
    </delete>

    <delete id="deleteBasCurrencyByIds" parameterType="String">
        delete from bas_currency where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>