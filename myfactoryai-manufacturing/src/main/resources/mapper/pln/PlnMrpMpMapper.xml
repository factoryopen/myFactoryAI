<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.pln.mapper.PlnMrpMpMapper">
    
    <resultMap type="PlnMrpMp" id="PlnMrpMpResult">
        <result property="id"    column="id"    />
        <result property="status"    column="status"    />
        <result property="mpsId"    column="mps_id"    />
        <result property="materialId"    column="material_id"    />
        <result property="materialCode"    column="material_code"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialSpec"    column="material_spec"    />
        <result property="quantity"    column="quantity"    />
        <result property="unitId"    column="unit_id"    />
        <result property="quantityWhgood"    column="quantity_whgood"    />
        <result property="quantityWhbooked"    column="quantity_whbooked"    />
        <result property="quantityWhavailable"    column="quantity_whavailable"    />
        <result property="consumeType"    column="consume_type"    />
        <result property="enableMust"    column="enable_must"    />
        <result property="enableReplace"    column="enable_replace"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectPlnMrpMpVo">
        select a.id, a.status, a.mps_id, a.material_id, a.material_code, a.material_name, a.material_spec,
               a.quantity, a.unit_id,
               b.quantity_qualified - b.quantity_scraped - b.quantity_expired - b.quantity_frozen - b.quantity_pending as quantity_whgood,
               b.quantity_booked as quantity_whbooked,
               b.quantity_qualified - b.quantity_scraped - b.quantity_expired - b.quantity_frozen - b.quantity_pending - b.quantity_booked as quantity_whavailable,
               a.consume_type, a.enable_must, a.enable_replace,
               a.remark, a.create_by, a.create_time, a.update_by, a.update_time
        from pln_mrp_mp a
        left join eng_material b on b.id=a.material_id
    </sql>

    <select id="selectPlnMrpMpList" parameterType="PlnMrpMp" resultMap="PlnMrpMpResult">
        <include refid="selectPlnMrpMpVo"/>
        <where>
            a.status in (0,4,13,14)
            <if test="id != null "> and a.id = #{id}</if>
            <if test="mpsId != null "> and a.mps_id = #{mpsId}</if>
            <if test="materialId != null "> and a.material_id = #{materialId}</if>
            <if test="materialCode != null  and materialCode != ''"> and a.material_code like concat('%', #{materialCode}, '%')</if>
            <if test="materialName != null  and materialName != ''"> and a.material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialSpec != null  and materialSpec != ''"> and a.material_spec like concat('%', #{materialSpec}, '%')</if>
            <if test="quantity != null "> and a.quantity = #{quantity}</if>
            <if test="unitId != null "> and a.unit_id = #{unitId}</if>
            <if test="consumeType != null "> and a.consume_type = #{consumeType}</if>
            <if test="enableMust != null  and enableMust != ''"> and a.enable_must = #{enableMust}</if>
            <if test="enableReplace != null  and enableReplace != ''"> and a.enable_replace = #{enableReplace}</if>
        </where>
    </select>
    
    <select id="selectPlnMrpMpById" parameterType="Long" resultMap="PlnMrpMpResult">
        <include refid="selectPlnMrpMpVo"/>
        where a.id = #{id}
    </select>

    <select id="selectPlnMrpMpListByMpsId" parameterType="Long" resultMap="PlnMrpMpResult">
        <include refid="selectPlnMrpMpVo"/>
        where a.mps_id = #{mpsId}
    </select>

    <select id="selectPlnMrpMpListByMaterialId" parameterType="Long" resultMap="PlnMrpMpResult">
        <include refid="selectPlnMrpMpVo"/>
        where a.material_id = #{materialId}
    </select>

    <select id="selectPlnMrpMpListByUnitId" parameterType="Long" resultMap="PlnMrpMpResult">
        <include refid="selectPlnMrpMpVo"/>
        where a.unit_id = #{unitId}
    </select>
        
    <insert id="insertPlnMrpMp" parameterType="PlnMrpMp" useGeneratedKeys="true" keyProperty="id">
        insert into pln_mrp_mp
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="status != null">status,</if>
            <if test="mpsId != null">mps_id,</if>
            <if test="materialId != null">material_id,</if>
            <if test="materialCode != null">material_code,</if>
            <if test="materialName != null">material_name,</if>
            <if test="materialSpec != null">material_spec,</if>
            <if test="quantity != null">quantity,</if>
            <if test="unitId != null">unit_id,</if>
            <if test="consumeType != null">consume_type,</if>
            <if test="enableMust != null">enable_must,</if>
            <if test="enableReplace != null">enable_replace,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="status != null">#{status},</if>
            <if test="mpsId != null">#{mpsId},</if>
            <if test="materialId != null">#{materialId},</if>
            <if test="materialCode != null">#{materialCode},</if>
            <if test="materialName != null">#{materialName},</if>
            <if test="materialSpec != null">#{materialSpec},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="unitId != null">#{unitId},</if>
            <if test="consumeType != null">#{consumeType},</if>
            <if test="enableMust != null">#{enableMust},</if>
            <if test="enableReplace != null">#{enableReplace},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updatePlnMrpMp" parameterType="PlnMrpMp">
        update pln_mrp_mp
        <trim prefix="SET" suffixOverrides=",">
            <if test="status != null">status = #{status},</if>
            <if test="mpsId != null">mps_id = #{mpsId},</if>
            <if test="materialId != null">material_id = #{materialId},</if>
            <if test="materialCode != null">material_code = #{materialCode},</if>
            <if test="materialName != null">material_name = #{materialName},</if>
            <if test="materialSpec != null">material_spec = #{materialSpec},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="unitId != null">unit_id = #{unitId},</if>
            <if test="consumeType != null">consume_type = #{consumeType},</if>
            <if test="enableMust != null">enable_must = #{enableMust},</if>
            <if test="enableReplace != null">enable_replace = #{enableReplace},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePlnMrpMpById" parameterType="Long">
        delete from pln_mrp_mp where id = #{id}
    </delete>

    <delete id="deletePlnMrpMpByIds" parameterType="String">
        delete from pln_mrp_mp where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deletePlnMrpMpByMpsId" parameterType="Long">
        delete from pln_mrp_mp where mps_id = #{mpsId}
    </delete>

    <delete id="deletePlnMrpMpByMaterialId" parameterType="Long">
        delete from pln_mrp_mp where material_id = #{materialId}
    </delete>

    <delete id="deletePlnMrpMpByUnitId" parameterType="Long">
        delete from pln_mrp_mp where unit_id = #{unitId}
    </delete>
</mapper>