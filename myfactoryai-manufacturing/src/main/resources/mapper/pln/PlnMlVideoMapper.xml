<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.pln.mapper.PlnMlVideoMapper">
    
    <resultMap type="PlnMlVideo" id="PlnMlVideoResult">
        <result property="id"    column="id"    />
        <result property="mlId"    column="ml_id"    />
        <result property="stepSeq"    column="step_seq"    />
        <result property="stepTitle"    column="step_title"    />
        <result property="description"    column="description"    />
        <result property="videoUrl"    column="video_url"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectPlnMlVideoVo">
        select id, ml_id, step_seq, step_title, description, video_url, remark, create_by, create_time, update_by, update_time from pln_ml_video
    </sql>

    <select id="selectPlnMlVideoList" parameterType="PlnMlVideo" resultMap="PlnMlVideoResult">
        <include refid="selectPlnMlVideoVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="mlId != null "> and ml_id = #{mlId}</if>
            <if test="stepSeq != null "> and step_seq = #{stepSeq}</if>
            <if test="stepTitle != null  and stepTitle != ''"> and step_title = #{stepTitle}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="videoUrl != null  and videoUrl != ''"> and video_url = #{videoUrl}</if>
        </where>
    </select>
    
    <select id="selectPlnMlVideoById" parameterType="Long" resultMap="PlnMlVideoResult">
        <include refid="selectPlnMlVideoVo"/>
        where id = #{id}
    </select>

    <select id="selectPlnMlVideoListByMlId" parameterType="Long" resultMap="PlnMlVideoResult">
        <include refid="selectPlnMlVideoVo"/>
        where ml_id = #{mlId}
    </select>
        
    <insert id="insertPlnMlVideo" parameterType="PlnMlVideo" useGeneratedKeys="true" keyProperty="id">
        insert into pln_ml_video
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="mlId != null">ml_id,</if>
            <if test="stepSeq != null">step_seq,</if>
            <if test="stepTitle != null and stepTitle != ''">step_title,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="videoUrl != null and videoUrl != ''">video_url,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="mlId != null">#{mlId},</if>
            <if test="stepSeq != null">#{stepSeq},</if>
            <if test="stepTitle != null and stepTitle != ''">#{stepTitle},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="videoUrl != null and videoUrl != ''">#{videoUrl},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updatePlnMlVideo" parameterType="PlnMlVideo">
        update pln_ml_video
        <trim prefix="SET" suffixOverrides=",">
            <if test="mlId != null">ml_id = #{mlId},</if>
            <if test="stepSeq != null">step_seq = #{stepSeq},</if>
            <if test="stepTitle != null and stepTitle != ''">step_title = #{stepTitle},</if>
            <if test="description != null and description != ''">description = #{description},</if>
            <if test="videoUrl != null and videoUrl != ''">video_url = #{videoUrl},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePlnMlVideoById" parameterType="Long">
        delete from pln_ml_video where id = #{id}
    </delete>

    <delete id="deletePlnMlVideoByIds" parameterType="String">
        delete from pln_ml_video where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deletePlnMlVideoByMlId" parameterType="Long">
        delete from pln_ml_video where ml_id = #{mlId}
    </delete>
</mapper>