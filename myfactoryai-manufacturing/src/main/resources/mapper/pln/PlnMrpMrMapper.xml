<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.pln.mapper.PlnMrpMrMapper">
    
    <resultMap type="PlnMrpMr" id="PlnMrpMrResult">
        <result property="id"    column="id"    />
        <result property="mpsId"    column="mps_id"    />
        <result property="status"    column="status"    />
        <result property="materialId"    column="material_id"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialSpec"    column="material_spec"    />
        <result property="unitId"    column="unit_id"    />
        <result property="quantity"    column="quantity"    />
        <result property="consumeType"    column="consume_type"    />
        <result property="enableMust"    column="enable_must"    />
        <result property="enableReplace"    column="enable_replace"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectPlnMrpMrVo">
        select id, mps_id, status, material_id, material_code, material_name, material_spec, unit_id, quantity,
               consume_type, enable_must, enable_replace, remark, create_by, create_time, update_by, update_time
        from pln_mrp_mr
    </sql>

    <select id="selectPlnMrpMrList" parameterType="PlnMrpMr" resultMap="PlnMrpMrResult">
        <include refid="selectPlnMrpMrVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="mpsId != null "> and mps_id = #{mpsId}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="materialId != null "> and material_id = #{materialId}</if>
            <if test="materialCode != null  and materialCode != ''"> and material_code like concat('%', #{materialCode}, '%')</if>
            <if test="materialName != null  and materialName != ''"> and material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialSpec != null  and materialSpec != ''"> and material_spec like concat('%', #{materialSpec}, '%')</if>
            <if test="unitId != null "> and unit_id = #{unitId}</if>
            <if test="quantity != null "> and quantity = #{quantity}</if>
            <if test="consumeType != null "> and consume_type = #{consumeType}</if>
            <if test="enableMust != null  and enableMust != ''"> and enable_must = #{enableMust}</if>
            <if test="enableReplace != null  and enableReplace != ''"> and enable_replace = #{enableReplace}</if>
        </where>
    </select>
    
    <select id="selectPlnMrpMrById" parameterType="Long" resultMap="PlnMrpMrResult">
        <include refid="selectPlnMrpMrVo"/>
        where id = #{id}
    </select>

    <select id="selectPlnMrpMrListByMpsId" parameterType="Long" resultMap="PlnMrpMrResult">
        <include refid="selectPlnMrpMrVo"/>
        where mps_id = #{mpsId}
    </select>

    <select id="selectPlnMrpMrListByMaterialId" parameterType="Long" resultMap="PlnMrpMrResult">
        <include refid="selectPlnMrpMrVo"/>
        where material_id = #{materialId}
    </select>

    <select id="selectPlnMrpMrListByUnitId" parameterType="Long" resultMap="PlnMrpMrResult">
        <include refid="selectPlnMrpMrVo"/>
        where unit_id = #{unitId}
    </select>
        
    <insert id="insertPlnMrpMr" parameterType="PlnMrpMr" useGeneratedKeys="true" keyProperty="id">
        insert into pln_mrp_mr
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="mpsId != null">mps_id,</if>
            <if test="status != null">status,</if>
            <if test="materialId != null">material_id,</if>
            <if test="materialCode != null and materialCode != ''">material_code,</if>
            <if test="materialName != null">material_name,</if>
            <if test="materialSpec != null">material_spec,</if>
            <if test="unitId != null">unit_id,</if>
            <if test="quantity != null">quantity,</if>
            <if test="consumeType != null">consume_type,</if>
            <if test="enableMust != null">enable_must,</if>
            <if test="enableReplace != null">enable_replace,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="mpsId != null">#{mpsId},</if>
            <if test="status != null">#{status},</if>
            <if test="materialId != null">#{materialId},</if>
            <if test="materialCode != null and materialCode != ''">#{materialCode},</if>
            <if test="materialName != null">#{materialName},</if>
            <if test="materialSpec != null">#{materialSpec},</if>
            <if test="unitId != null">#{unitId},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="consumeType != null">#{consumeType},</if>
            <if test="enableMust != null">#{enableMust},</if>
            <if test="enableReplace != null">#{enableReplace},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updatePlnMrpMr" parameterType="PlnMrpMr">
        update pln_mrp_mr
        <trim prefix="SET" suffixOverrides=",">
            <if test="mpsId != null">mps_id = #{mpsId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="materialId != null">material_id = #{materialId},</if>
            <if test="materialCode != null and materialCode != ''">material_code = #{materialCode},</if>
            <if test="materialName != null">material_name = #{materialName},</if>
            <if test="materialSpec != null">material_spec = #{materialSpec},</if>
            <if test="unitId != null">unit_id = #{unitId},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="consumeType != null">consume_type = #{consumeType},</if>
            <if test="enableMust != null">enable_must = #{enableMust},</if>
            <if test="enableReplace != null">enable_replace = #{enableReplace},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePlnMrpMrById" parameterType="Long">
        delete from pln_mrp_mr where id = #{id}
    </delete>

    <delete id="deletePlnMrpMrByIds" parameterType="String">
        delete from pln_mrp_mr where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deletePlnMrpMrByMpsId" parameterType="Long">
        delete from pln_mrp_mr where mps_id = #{mpsId}
    </delete>

    <delete id="deletePlnMrpMrByMaterialId" parameterType="Long">
        delete from pln_mrp_mr where material_id = #{materialId}
    </delete>

    <delete id="deletePlnMrpMrByUnitId" parameterType="Long">
        delete from pln_mrp_mr where unit_id = #{unitId}
    </delete>
</mapper>