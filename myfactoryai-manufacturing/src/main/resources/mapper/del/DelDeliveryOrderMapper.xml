    <sql id="selectDelDeliveryOrderVo">
        select id, bill_no, status, customer_id, delivery_day, address_id, contact, phone, express_no, invoice_no, project_id, sales_id,
               remark, create_by, create_time, update_by, update_time
        from del_gd
