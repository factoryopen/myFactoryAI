            <if test="invoiceNo != null  and invoiceNo != ''"> and invoice_no like concat('%', #{invoiceNo}, '%')</if>
            <if test="projectId != null "> and project_id = #{projectId}</if>
            <if test="salesId != null "> and sales_id = #{salesId}</if>
        </where>
        order by update_time desc
    </select>

