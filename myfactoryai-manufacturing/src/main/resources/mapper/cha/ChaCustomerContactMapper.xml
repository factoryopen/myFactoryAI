<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.factoryopen.myfactoryai.manufacturing.cha.mapper.ChaCustomerContactMapper">
    
    <resultMap type="ChaCustomerContact" id="ChaCustomerContactResult">
        <result property="id"    column="id"    />
        <result property="customerId"    column="customer_id"    />
        <result property="contact"    column="contact"    />
        <result property="talkLevel"    column="talk_level"    />
        <result property="cellphone1"    column="cellphone1"    />
        <result property="cellphone2"    column="cellphone2"    />
        <result property="wechat"    column="wechat"    />
        <result property="email"    column="email"    />
        <result property="telephone"    column="telephone"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectChaCustomerContactVo">
        select id, customer_id, contact, talk_level, cellphone1, cellphone2, wechat, email, telephone, remark, create_by, create_time, update_by, update_time from cha_customer_contact
    </sql>

    <select id="selectChaCustomerContactList" parameterType="ChaCustomerContact" resultMap="ChaCustomerContactResult">
        <include refid="selectChaCustomerContactVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="customerId != null "> and customer_id = #{customerId}</if>
            <if test="contact != null  and contact != ''"> and contact = #{contact}</if>
            <if test="talkLevel != null  and talkLevel != ''"> and talk_level = #{talkLevel}</if>
            <if test="cellphone1 != null  and cellphone1 != ''"> and cellphone1 = #{cellphone1}</if>
            <if test="cellphone2 != null  and cellphone2 != ''"> and cellphone2 = #{cellphone2}</if>
            <if test="wechat != null  and wechat != ''"> and wechat = #{wechat}</if>
            <if test="email != null  and email != ''"> and email = #{email}</if>
            <if test="telephone != null  and telephone != ''"> and telephone = #{telephone}</if>
        </where>
    </select>
    
    <select id="selectChaCustomerContactById" parameterType="Long" resultMap="ChaCustomerContactResult">
        <include refid="selectChaCustomerContactVo"/>
        where id = #{id}
    </select>

    <select id="selectChaCustomerContactListByCustomerId" parameterType="Long" resultMap="ChaCustomerContactResult">
        <include refid="selectChaCustomerContactVo"/>
        where customer_id = #{customerId}
    </select>
        
    <insert id="insertChaCustomerContact" parameterType="ChaCustomerContact" useGeneratedKeys="true" keyProperty="id">
        insert into cha_customer_contact
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="customerId != null">customer_id,</if>
            <if test="contact != null">contact,</if>
            <if test="talkLevel != null">talk_level,</if>
            <if test="cellphone1 != null">cellphone1,</if>
            <if test="cellphone2 != null">cellphone2,</if>
            <if test="wechat != null">wechat,</if>
            <if test="email != null">email,</if>
            <if test="telephone != null">telephone,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="customerId != null">#{customerId},</if>
            <if test="contact != null">#{contact},</if>
            <if test="talkLevel != null">#{talkLevel},</if>
            <if test="cellphone1 != null">#{cellphone1},</if>
            <if test="cellphone2 != null">#{cellphone2},</if>
            <if test="wechat != null">#{wechat},</if>
            <if test="email != null">#{email},</if>
            <if test="telephone != null">#{telephone},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateChaCustomerContact" parameterType="ChaCustomerContact">
        update cha_customer_contact
        <trim prefix="SET" suffixOverrides=",">
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="contact != null">contact = #{contact},</if>
            <if test="talkLevel != null">talk_level = #{talkLevel},</if>
            <if test="cellphone1 != null">cellphone1 = #{cellphone1},</if>
            <if test="cellphone2 != null">cellphone2 = #{cellphone2},</if>
            <if test="wechat != null">wechat = #{wechat},</if>
            <if test="email != null">email = #{email},</if>
            <if test="telephone != null">telephone = #{telephone},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteChaCustomerContactById" parameterType="Long">
        delete from cha_customer_contact where id = #{id}
    </delete>

    <delete id="deleteChaCustomerContactByIds" parameterType="String">
        delete from cha_customer_contact where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteChaCustomerContactByCustomerId" parameterType="Long">
        delete from cha_customer_contact where customer_id = #{customerId}
    </delete>
</mapper>