        delete from eng_product_bom where id = #{id}
    </delete>

    <delete id="deleteEngProductBomByIds" parameterType="String">
        delete from eng_product_bom where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteEngProductBomByProductId" parameterType="Long">
        delete from eng_product_bom where product_id = #{productId}
    </delete>

    <delete id="deleteEngProductBomByMaterialId" parameterType="Long">
        delete from eng_product_bom where material_id = #{materialId}
