<mapper namespace="net.factoryopen.myfactoryai.manufacturing.eng.mapper.EngProductBomMapper">
    
    <resultMap type="EngProductBom" id="EngProductBomResult">
        <result property="id"    column="id"    />
        <result property="productId"    column="product_id"    />
        <result property="seqNo"    column="seq_no"    />
        <result property="materialId"    column="material_id"    />
        <result property="materialCode"    column="material_code"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialSpec"    column="material_spec"    />
        <result property="materialSize"    column="material_size"    />
        <result property="drawNo"    column="draw_no"    />
        <result property="categoryId"    column="category_id"    />
        <result property="compoundId"    column="compound_id"    />
        <result property="standardQuantity"    column="standard_quantity"    />
        <result property="lossRate"    column="loss_rate"    />
        <result property="consumeType"    column="consume_type"    />
        <result property="enableMust"    column="enable_must"    />
        <result property="enableReplace"    column="enable_replace"    />
        <result property="lineId"    column="line_id"    />
        <result property="calculateType"    column="calculate_type"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
