            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateEngCategoryBom" parameterType="EngCategoryBom">
        update eng_category_bom
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="seqNo != null">seq_no = #{seqNo},</if>
            <if test="materialId != null">material_id = #{materialId},</if>
            <if test="materialName != null and materialName != ''">material_name = #{materialName},</if>
            <if test="materialSpec != null">material_spec = #{materialSpec},</if>
            <if test="standardQuantity != null">standard_quantity = #{standardQuantity},</if>
            <if test="lossRate != null">loss_rate = #{lossRate},</if>
            <if test="consumeType != null">consume_type = #{consumeType},</if>
            <if test="calculateType != null and calculateType != ''">calculate_type = #{calculateType},</if>
            <if test="lineId != null">line_id = #{lineId},</if>
