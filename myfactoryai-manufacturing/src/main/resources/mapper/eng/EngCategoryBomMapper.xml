    </delete>

    <delete id="deleteEngCategoryBomByIds" parameterType="String">
        delete from eng_category_bom where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteEngCategoryBomByCategoryId" parameterType="Long">
        delete from eng_category_bom where category_id = #{categoryId}
