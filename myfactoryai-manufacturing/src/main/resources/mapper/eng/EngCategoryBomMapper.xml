<mapper namespace="net.factoryopen.myfactoryai.manufacturing.eng.mapper.EngCategoryBomMapper">
    
    <resultMap type="EngCategoryBom" id="EngCategoryBomResult">
        <result property="id"    column="id"    />
        <result property="categoryId"    column="category_id"    />
        <result property="seqNo"    column="seq_no"    />
        <result property="materialId"    column="material_id"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialSpec"    column="material_spec"    />
        <result property="standardQuantity"    column="standard_quantity"    />
        <result property="lossRate"    column="loss_rate"    />
