    <sql id="selectEngCategoryBomVo">
        select id, category_id, seq_no, material_id, material_name, material_spec, standard_quantity, loss_rate, consume_type, calculate_type, line_id, remark, create_by, create_time, update_by, update_time from eng_category_bom
    </sql>

    <select id="selectEngCategoryBomList" parameterType="EngCategoryBom" resultMap="EngCategoryBomResult">
        <include refid="selectEngCategoryBomVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="seqNo != null "> and seq_no like concat('%', #{seqNo}, '%')</if>
            <if test="materialId != null "> and material_id = #{materialId}</if>
            <if test="materialName != null  and materialName != ''"> and material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialSpec != null  and materialSpec != ''"> and material_spec like concat('%', #{materialSpec}, '%')</if>
            <if test="standardQuantity != null "> and standard_quantity = #{standardQuantity}</if>
            <if test="lossRate != null "> and loss_rate = #{lossRate}</if>
            <if test="consumeType != null "> and consume_type = #{consumeType}</if>
            <if test="calculateType != null  and calculateType != ''"> and calculate_type = #{calculateType}</if>
            <if test="lineId != null "> and line_id = #{lineId}</if>
        </where>
    </select>
    
    <select id="selectEngCategoryBomById" parameterType="Long" resultMap="EngCategoryBomResult">
        <include refid="selectEngCategoryBomVo"/>
        where id = #{id}
    </select>

    <select id="selectEngCategoryBomListByCategoryId" parameterType="Long" resultMap="EngCategoryBomResult">
        <include refid="selectEngCategoryBomVo"/>
        where category_id = #{categoryId}
    </select>

    <select id="selectEngCategoryBomListByMaterialId" parameterType="Long" resultMap="EngCategoryBomResult">
        <include refid="selectEngCategoryBomVo"/>
        where material_id = #{materialId}
    </select>

    <select id="selectEngCategoryBomListByLineId" parameterType="Long" resultMap="EngCategoryBomResult">
        <include refid="selectEngCategoryBomVo"/>
        where line_id = #{lineId}
    </select>
        
    <insert id="insertEngCategoryBom" parameterType="EngCategoryBom" useGeneratedKeys="true" keyProperty="id">
        insert into eng_category_bom
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="seqNo != null">seq_no,</if>
            <if test="materialId != null">material_id,</if>
            <if test="materialName != null and materialName != ''">material_name,</if>
            <if test="materialSpec != null">material_spec,</if>
            <if test="standardQuantity != null">standard_quantity,</if>
            <if test="lossRate != null">loss_rate,</if>
            <if test="consumeType != null">consume_type,</if>
            <if test="calculateType != null and calculateType != ''">calculate_type,</if>
            <if test="lineId != null">line_id,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
