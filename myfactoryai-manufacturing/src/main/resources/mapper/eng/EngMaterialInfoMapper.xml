    <sql id="selectEngMaterialInfoVo">
        select id, material_code, material_name, material_spec, draw_no, unit_id, customer_product_no, abroad_product_no, category_id, compound_id,
               base_type, purchase_type, consume_type, line_id, rate_loss, days_cycletime, days_leadtime, days_posttime, price_last, price_buy, price_sale, status,
               quantity_qualified, quantity_scraped, quantity_expired, quantity_frozen, quantity_pending, quantity_booked,
               house_id, position_id,
               remark, create_by, create_time, update_by, update_time
        from eng_material
    </sql>

    <select id="selectEngMaterialInfoList" parameterType="EngMaterialInfo" resultMap="EngMaterialInfoResult">
        <include refid="selectEngMaterialInfoVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="materialCode != null  and materialCode != ''"> and material_code like concat('%', #{materialCode}, '%')</if>
            <if test="materialName != null  and materialName != ''"> and material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialSpec != null  and materialSpec != ''"> and material_spec like concat('%', #{materialSpec}, '%')</if>
            <if test="drawNo != null  and drawNo != ''"> and draw_no like concat('%', #{drawNo}, '%')</if>
            <if test="customerProductNo != null  and customerProductNo != ''"> and customer_product_no like concat('%', #{customerProductNo}, '%')</if>
            <if test="abroadProductNo != null  and abroadProductNo != ''"> and abroad_product_no like concat('%', #{abroadProductNo}, '%')</if>
            <if test="unitId != null "> and unit_id = #{unitId}</if>
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="compoundId != null "> and compound_id = #{compoundId}</if>
            <if test="houseId != null "> and house_id = #{houseId}</if>
            <if test="positionId != null "> and position_id = #{positionId}</if>
            <if test="purchaseType != null  and purchaseType != ''"> and purchase_type = #{purchaseType}</if>
            <if test="consumeType != null  and consumeType != ''"> and consume_type = #{consumeType}</if>
            <if test="priceLast != null "> and price_last = #{priceLast}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="quantityBooked != null "> and quantity_booked = #{quantityBooked}</if>
            and material_code not like 'T0%'
        </where>
        order by update_time desc
    </select>

