    <select id="filterMaterialList" parameterType="EngMaterialInfo" resultMap="EngMaterialInfoResult">
        <include refid="selectEngMaterialInfoVo"/>
        where (material_code like concat('%', #{materialName}, '%')
                or material_name like concat('%', #{materialName}, '%')
                or draw_no like concat('%', #{materialName}, '%')
                )
              and material_code not like 'T0%'
        order by update_time desc
    </select>
    
