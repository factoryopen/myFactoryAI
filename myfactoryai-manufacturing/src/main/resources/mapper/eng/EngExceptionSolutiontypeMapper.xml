    <sql id="selectEngExceptionSolutiontypeVo">
        select id, category_id, dealtype_code, dealtype_desc, status, remark, create_by, create_time, update_by, update_time from eng_exception_solutiontype
    </sql>

    <select id="selectEngExceptionSolutiontypeList" parameterType="EngExceptionSolutiontype" resultMap="EngExceptionSolutiontypeResult">
        <include refid="selectEngExceptionSolutiontypeVo"/>
        <where>
            <if test="id != null "> and id = #{id}</if>
            <if test="categoryId != null "> and category_id = #{categoryId}</if>
            <if test="dealtypeCode != null  and dealtypeCode != ''"> and dealtype_code like concat('%', #{dealtypeCode}, '%')</if>
            <if test="dealtypeDesc != null  and dealtypeDesc != ''"> and dealtype_desc like concat('%', #{dealtypeDesc}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectEngExceptionSolutiontypeById" parameterType="Long" resultMap="EngExceptionSolutiontypeResult">
        <include refid="selectEngExceptionSolutiontypeVo"/>
        where id = #{id}
    </select>

    <select id="selectEngExceptionSolutiontypeListByCategoryId" parameterType="Long" resultMap="EngExceptionSolutiontypeResult">
        <include refid="selectEngExceptionSolutiontypeVo"/>
        where category_id = #{categoryId}
    </select>
        
    <insert id="insertEngExceptionSolutiontype" parameterType="EngExceptionSolutiontype" useGeneratedKeys="true" keyProperty="id">
        insert into eng_exception_solutiontype
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="dealtypeCode != null and dealtypeCode != ''">dealtype_code,</if>
            <if test="dealtypeDesc != null and dealtypeDesc != ''">dealtype_desc,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if test="dealtypeCode != null and dealtypeCode != ''">#{dealtypeCode},</if>
            <if test="dealtypeDesc != null and dealtypeDesc != ''">#{dealtypeDesc},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateEngExceptionSolutiontype" parameterType="EngExceptionSolutiontype">
        update eng_exception_solutiontype
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="dealtypeCode != null and dealtypeCode != ''">dealtype_code = #{dealtypeCode},</if>
            <if test="dealtypeDesc != null and dealtypeDesc != ''">dealtype_desc = #{dealtypeDesc},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteEngExceptionSolutiontypeById" parameterType="Long">
        delete from eng_exception_solutiontype where id = #{id}
    </delete>

    <delete id="deleteEngExceptionSolutiontypeByIds" parameterType="String">
        delete from eng_exception_solutiontype where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteEngExceptionSolutiontypeByCategoryId" parameterType="Long">
        delete from eng_exception_solutiontype where category_id = #{categoryId}
    </delete>
