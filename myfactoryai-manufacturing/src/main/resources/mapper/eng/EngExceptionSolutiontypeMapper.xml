<mapper namespace="net.factoryopen.myfactoryai.manufacturing.eng.mapper.EngExceptionSolutiontypeMapper">
    
    <resultMap type="EngExceptionSolutiontype" id="EngExceptionSolutiontypeResult">
        <result property="id"    column="id"    />
        <result property="categoryId"    column="category_id"    />
        <result property="dealtypeCode"    column="dealtype_code"    />
        <result property="dealtypeDesc"    column="dealtype_desc"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
