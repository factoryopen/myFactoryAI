    </delete>

    <delete id="deleteEngPruductRoutingvideoByIds" parameterType="String">
        delete from eng_pruduct_routingvideo where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
